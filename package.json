    "ai:loop": "node scripts/ai_loop.mjs",
    "ai:daemon": "node scripts/ai_daemon.mjs",
    "evo:dev": "tsx tools/evoforge/cli/evo.ts dev",
    "evo:build": "tsx tools/evoforge/cli/evo.ts build",
    "evo:audit": "tsx tools/evoforge/cli/evo.ts audit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
