{
  "name": "prompthouse-evo-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "singularity": "concurrently \"npm run dev\" \"cd evogenage && npm run dev -- --port 5174\"",
    "build": "vite build",
    "test": "vitest run",
    "start": "node promptbridge-server.js",
    "preview": "vite preview",
    "bridge": "node promptbridge-server.js",
    "rift:bridge": "node riftgrid-server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run bridge\" \"npm run rift:bridge\"",
    "verify:agent": "node verify-agent-setup.js",
    "create:agent": "node openai-agent-modern.js",
    "test:agent": "node agent-runtime.js 'Explain your core mission in 2-3 sentences'",
    "agent:repl": "node agent-runtime.js --repl",
    "integrate:agent": "node integrate-agent.js",
    "ai:pack": "node scripts/ai_context_pack.mjs",
    "ai:review": "node scripts/ai_review_openai.mjs",
    "ai:train": "node scripts/ai_self_train.mjs",
    "ai:loop": "node scripts/ai_loop.mjs",
    "ai:daemon": "node scripts/ai_daemon.mjs",
    "audit:nuclear": "node scripts/nuclear_audit.mjs",
    "evo:dev": "tsx tools/evoforge/cli/evo.ts dev",
    "evo:build": "tsx tools/evoforge/cli/evo.ts build",
    "evo:audit": "tsx tools/evoforge/cli/evo.ts audit",
    "audit:css": "node scripts/audit-css-vars.mjs",
    "audit:imports": "node scripts/audit-imports.mjs",
    "verify:studio": "node scripts/verify-studio.mjs",
    "proof:report": "node scripts/generate-proof-report.mjs",
    "deployment:readiness": "node scripts/deployment-readiness-report.mjs",
    "simulate:local-production": "node scripts/local-production-sim.mjs",
    "preview:smoke": "node scripts/preview-smoke-check.mjs",
    "handover:report": "node scripts/generate-handover-report.mjs",
    "docs:warnings": "node scripts/markdown-warning-report.mjs",
    "backend:routes": "node scripts/print-backend-routes.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents": "^0.11.4",
    "@rive-app/react-canvas": "^4.28.4",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.14.0",
    "node-fetch": "^3.3.2",
    "openai": "^6.37.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.7.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
