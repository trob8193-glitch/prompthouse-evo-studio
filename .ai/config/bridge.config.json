{
  "maxFileBytes": 120000,
  "maxTotalBytes": 45000,
  "includeExtensions": [
    ".dart",
    ".yaml",
    ".yml",
    ".json",
    ".js",
    ".mjs",
    ".ts",
    ".tsx",
    ".jsx",
    ".md",
    ".rules",
    ".gradle",
    ".properties"
  ],
  "alwaysIncludeFiles": [
    "package.json",
    "pubspec.yaml",
    "analysis_options.yaml",
    "firebase.json",
    "docs/knowledge/evolution_and_optimization.md",
    "docs/knowledge/ui_and_image_generation.md",
    "docs/knowledge/vite_and_connections.md",
    "docs/knowledge/visuals_and_evolution.md",
    "docs/knowledge/session_evolution.md",
    "docs/knowledge/llm_model_training.md",
    "docs/knowledge/precise_cutting.md",
    "docs/knowledge/creative_autonomy.md",
    "docs/knowledge/tree_and_web_architecture.md",
    "docs/knowledge/advanced_evolution_and_automation.md",
    "docs/knowledge/advanced_patterns_and_awareness.md",
    "docs/knowledge/autonomous_code_generation.md",
    "docs/knowledge/advanced_tools_and_self_invention.md",
    "firestore.rules",
    "storage.rules",
    "functions/package.json",
    "functions/src/index.ts",
    "functions/tsconfig.json",
    ".github/workflows"
  ],
  "scanRoots": [
    "lib",
    "test",
    "integration_test",
    "functions/src",
    "firebase",
    "scripts",
    ".github/workflows",
    "src"
  ],
  "excludePaths": [
    ".env",
    ".ai/context-pack.json",
    ".ai/snapshots/context-pack.json",
    ".ai/secrets",
    ".git",
    "node_modules",
    "build",
    "dist",
    "coverage",
    ".dart_tool",
    "android/.gradle",
    "ios/Pods",
    "ios/.symlinks",
    "macos/Pods",
    "windows/flutter/ephemeral",
    "linux/flutter/ephemeral"
  ],
  "excludeGlobs": [
    ".env.*",
    "*.key",
    "*.pem",
    "*.p12",
    "*.jks",
    "*.keystore",
    "serviceAccount*.json",
    "firebase-adminsdk*.json",
    "google-services-private.json",
    "google-services.json",
    "GoogleService-Info.plist",
    "android/key.properties",
    "android/app/*.jks",
    "android/app/*.keystore",
    "ios/Runner/*.mobileprovision"
  ],
  "outputSnapshotPath": ".ai/snapshots/context-pack.json",
  "summaryOutputPath": ".ai/snapshots/context-summary.md",
  "modelEnvVar": "OPENAI_MODEL",
  "fallbackModel": "gpt-5.1",
  "reviewOutputPath": ".ai/outbox/gpt-review.md",
  "antigravityPromptOutputPath": ".ai/outbox/antigravity-next-pass.md",
  "repairChecklistOutputPath": ".ai/outbox/repair-checklist.md"
}
