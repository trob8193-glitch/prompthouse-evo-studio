{
  "manifest_version": 3,
  "name": "PH Evo Bridge",
  "version": "0.1.0",
  "description": "PH Evo PromptBridge browser cockpit and local gateway connector.",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "http://127.0.0.1:4317/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content/chatgpt-content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "PH Evo Bridge"
  }
}