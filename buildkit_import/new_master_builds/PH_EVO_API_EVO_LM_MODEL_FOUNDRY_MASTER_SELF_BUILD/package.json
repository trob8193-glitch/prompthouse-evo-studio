{
  "name": "ph-evo-api-evo-lm-master-self-build",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "npm --prefix apps/local-gateway run dev",
    "test:gateway": "curl http://127.0.0.1:4317/health",
    "build:datasets": "python model-foundry/dataset-forge/build_sft_from_events.py --events data/sample_events.jsonl --out data/sft.jsonl",
    "sanitize:sft": "python model-foundry/sanitizer/sanitize_jsonl.py --in data/sft.jsonl --out data/sft.sanitized.jsonl"
  }
}
