{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PromptLinkConnectorManifest",
  "type": "object",
  "required": [
    "connectorId",
    "name",
    "baseUrl",
    "auth",
    "capabilities",
    "allowedActions",
    "riskLevel"
  ],
  "properties": {
    "connectorId": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "name": {
      "type": "string"
    },
    "baseUrl": {
      "type": "string"
    },
    "auth": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "none",
            "bearer_env",
            "api_key_header",
            "oauth2"
          ]
        },
        "secretRef": {
          "type": "string"
        },
        "headerName": {
          "type": "string"
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowedActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "riskLevel": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "proofPolicy": {
      "type": "string"
    },
    "rateLimits": {
      "type": "object"
    }
  }
}