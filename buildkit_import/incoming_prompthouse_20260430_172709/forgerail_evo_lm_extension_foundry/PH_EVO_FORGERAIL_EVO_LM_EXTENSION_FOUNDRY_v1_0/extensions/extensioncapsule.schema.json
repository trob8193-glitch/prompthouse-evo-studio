{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExtensionCapsule",
  "type": "object",
  "required": [
    "extension",
    "owner",
    "risk",
    "targets",
    "artifacts",
    "proof"
  ],
  "properties": {
    "extension": {
      "type": "object",
      "required": [
        "name",
        "type",
        "purpose"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "owner": {
      "type": "object",
      "properties": {
        "lead_bot": {
          "type": "string"
        },
        "support_bots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "risk": {
      "type": "object",
      "properties": {
        "level": {
          "enum": [
            "low",
            "medium",
            "high",
            "destructive"
          ]
        },
        "approval_required": {
          "type": "boolean"
        }
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "install": {
      "type": "object"
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proof": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback": {
      "type": "string"
    }
  }
}
