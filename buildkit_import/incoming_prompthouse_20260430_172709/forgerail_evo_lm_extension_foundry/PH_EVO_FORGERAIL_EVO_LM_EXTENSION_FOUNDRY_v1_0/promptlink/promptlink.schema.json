{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PromptLinkConnector",
  "type": "object",
  "required": [
    "provider_id",
    "provider_type",
    "auth_type",
    "capabilities",
    "approval_policy",
    "secret_refs"
  ],
  "properties": {
    "provider_id": {
      "type": "string"
    },
    "provider_type": {
      "type": "string"
    },
    "auth_type": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_policy": {
      "type": "string"
    },
    "secret_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
