BRIDGE_PORT=3001
VITE_BRIDGE_URL=http://127.0.0.1:3001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

JWT_SECRET=replace_with_a_very_long_random_secret_min_24_chars
PH_EVO_MASTER_KEY=replace_with_master_api_key
OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_MODEL=replace_with_current_model_name
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
STRIPE_SECRET_KEY=
VERCEL_TOKEN=
REQUIRE_AUTH_MUTATIONS=true

# ─── Deployment Configuration ─────────────────────────────────
# PUBLIC_FRONTEND_URL: Public URL of the deployed frontend (used for CORS)
PUBLIC_FRONTEND_URL=
# PUBLIC_BRIDGE_URL: Public URL of the deployed bridge server
PUBLIC_BRIDGE_URL=
# VERCEL_PROJECT_ID: Project ID from Vercel dashboard
VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID: Team ID from Vercel dashboard (optional for personal accounts)
VERCEL_TEAM_ID=
# DEPLOY_TARGET: 'local' or 'vercel' — controls which adapter is used
DEPLOY_TARGET=local
# DEPLOY_ALLOW_PRODUCTION: Set to 'true' ONLY when owner-approved production deploy is intended
# Preview deploys do not require this. Production deploys require this + owner approval.
DEPLOY_ALLOW_PRODUCTION=false

