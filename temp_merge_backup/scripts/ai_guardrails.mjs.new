import fs from 'fs';
import fsPromises from 'fs/promises';
import path from 'path';

export function getProjectRoot() {
  return path.resolve(process.cwd());
}

export function isPathInsideProject(root, target) {
  const resolvedRoot = path.resolve(root);
  const resolvedTarget = path.resolve(target);
  const relative = path.relative(resolvedRoot, resolvedTarget).replace(/\\/g, '/');
  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));
}

export function normalizeRelativePath(root, target) {
  const relative = path.relative(root, target).replace(/\\/g, '/');
  return relative.startsWith('./') ? relative.slice(2) : relative;
}

export async function ensureDir(dirPath) {
  await fsPromises.mkdir(dirPath, { recursive: true });
}

export async function writeTextFileSafe(root, relativePath, content) {
  const target = path.resolve(root, relativePath);
  if (!isPathInsideProject(root, target)) {
    throw new Error(`Attempted to write outside project root: ${relativePath}`);
  }

  await ensureDir(path.dirname(target));
  await fsPromises.writeFile(target, content, 'utf8');
}

export async function safeReadTextFile(filePath, maxBytes = 120000) {
  const resolved = path.resolve(filePath);
  const root = getProjectRoot();
  if (!isPathInsideProject(root, resolved)) {
    throw new Error(`Read outside project root blocked: ${filePath}`);
  }
  const stats = await fsPromises.stat(resolved);
  if (stats.size > maxBytes) {
    throw new Error(`File exceeds max size: ${stats.size} bytes`);
  }
  return fsPromises.readFile(resolved, 'utf8');
}

export function fileExists(filePath) {
  try {
    fs.accessSync(filePath);
    return true;
  } catch {
    return false;
  }
}

function globToRegex(glob) {
  const escaped = glob.replace(/[-/\\^$+?.()|[\]{}]/g, '\\$&');
  const regexText = '^' + escaped.replace(/\\\*/g, '.*').replace(/\\\?/g, '.') + '$';
  return new RegExp(regexText, 'i');
}

export function looksSensitivePath(relativePath) {
  const normalized = relativePath.replace(/\\/g, '/');
  const patterns = [
    /^\\.env($|\\/|\\.)/i,
    /\\.env\\./i,
    /\\.key$/i,
    /\\.pem$/i,
    /\\.p12$/i,
    /\\.jks$/i,
    /\\.keystore$/i,
    /serviceaccount.*\\.json$/i,
    /firebase-adminsdk.*\\.json$/i,
    /google-services-private\\.json$/i,
    /google-services.*\\.json$/i,
    /GoogleService-Info\\.plist$/i,
    /android\\/key\\.properties$/i,
    /android\\/app\\/.*\\.jks$/i,
    /android\\/app\\/.*\\.keystore$/i,
    /ios\\/Runner\\/.*\\.mobileprovision$/i,
    /^\\.git($|\\/)/i,
    /^node_modules($|\\/)/i,
    /^build($|\\/)/i,
    /^dist($|\\/)/i,
    /^coverage($|\\/)/i,
    /^\\.dart_tool($|\\/)/i,
    /^android\\/\\.gradle($|\\/)/i,
    /^ios\\/Pods($|\\/)/i,
    /^ios\\/\\.symlinks($|\\/)/i,
    /^macos\\/Pods($|\\/)/i,
    /^windows\\/flutter\\/ephemeral($|\\/)/i,
    /^linux\\/flutter\\/ephemeral($|\\/)/i
  ];
  return patterns.some(regex => regex.test(normalized));
}

export function shouldExclude(relativePath, config) {
  const normalized = relativePath.replace(/\\/g, '/');

  if (config.excludePaths.some(p => normalized === p || normalized.startsWith(`${p}/`))) {
    return true;
  }

  if (config.excludeGlobs.some(glob => globToRegex(glob).test(normalized))) {
    return true;
  }

  return looksSensitivePath(normalized);
}

export function looksSensitiveContent(text) {
  const patterns = [
    /sk-[A-Za-z0-9]{32,}/i,
    /OPENAI[_-]?API[_-]?KEY/i,
    /API[_-]?KEY\\s*=/i,
    /STRIPE[_-]?SECRET(?:[_-]?KEY)?/i,
    /FIREBASE[_-]?PRIVATE[_-]?KEY/i,
    /-----BEGIN [A-Z ]*PRIVATE KEY-----/i,
    /client[_-]?secret/i,
    /refresh[_-]?token/i,
    /access[_-]?token/i,
    /password\\s*=/i,
    /authorization\\s*:\\s*Bearer\\s+[A-Za-z0-9\\-\\._~+\\/]+=*/i,
    /Bearer\\s+[A-Za-z0-9\\-\\._~+\\/]+=*/i,
    /[A-Za-z0-9-_]{20,}\\.[A-Za-z0-9-_]{20,}\\.[A-Za-z0-9-_]{20,}/
  ];
  return patterns.some(regex => regex.test(text));
}

export function redactSensitiveText(text) {
  let redacted = text;
  const replacements = [
    { regex: /sk-[A-Za-z0-9]{32,}/g, replacement: '[REDACTED_SECRET]' },
    {
      regex: /(?:OPENAI[_-]?API[_-]?KEY|API[_-]?KEY|STRIPE[_-]?SECRET(?:[_-]?KEY)?|FIREBASE[_-]?PRIVATE[_-]?KEY|client[_-]?secret|refresh[_-]?token|access[_-]?token|password)\\s*[:=]\\s*['\"]?[^'\"\\s]+['\"]?/gi,
      replacement: '[REDACTED_SECRET]'
    },
    { regex: /authorization\\s*:\\s*Bearer\\s+[A-Za-z0-9\\-\\._~+\\/]+=*/gi, replacement: 'authorization: Bearer [REDACTED_SECRET]' },
    { regex: /Bearer\\s+[A-Za-z0-9\\-\\._~+\\/]+=*/gi, replacement: 'Bearer [REDACTED_SECRET]' },
    { regex: /-----BEGIN [A-Z ]*PRIVATE KEY-----[\\s\\S]*?-----END [A-Z ]*PRIVATE KEY-----/gi, replacement: '[REDACTED_PRIVATE_KEY]' },
    { regex: /[A-Za-z0-9-_]{20,}\\.[A-Za-z0-9-_]{20,}\\.[A-Za-z0-9-_]{20,}/g, replacement: '[REDACTED_JWT]' }
  ];

  replacements.forEach(({ regex, replacement }) => {
    redacted = redacted.replace(regex, replacement);
  });

  const home = process.env.HOME || process.env.USERPROFILE;
  if (home) {
    redacted = redacted.replace(new RegExp(home.replace(/[\\/\\^$*+?.()|[\]{}]/g, '\\$&'), 'g'), '[REDACTED_PATH]');
  }

  redacted = redacted
    .replace(/([A-Za-z]:\\[^\\s'\"`]+)/g, '[REDACTED_PATH]')
    .replace(/\\/Users\\/[^\\s'\"`]+\\/[^\\s'\"`]+/g, '[REDACTED_PATH]')
    .replace(/\\/home\\/[^\\s'\"`]+\\/[^\\s'\"`]+/g, '[REDACTED_PATH]');

  return redacted;
}

export async function listFilesSafe(root, scanRoots, config) {
  const normalizedRoot = path.resolve(root);
  const visited = new Map();
  const skippedFiles = [];
  const alwaysIncludeRoots = config.alwaysIncludeFiles.map(p => p.replace(/\\/g, '/'));

  function isAlwaysIncluded(relative) {
    return alwaysIncludeRoots.some(prefix => relative === prefix || relative.startsWith(`${prefix}/`));
  }

  async function addFile(fullPath) {
    const relative = normalizeRelativePath(normalizedRoot, fullPath);
    if (shouldExclude(relative, config)) {
      skippedFiles.push({ path: relative, reason: 'Excluded by config or sensitive path' });
      return;
    }
    if (!isPathInsideProject(normalizedRoot, fullPath)) {
      skippedFiles.push({ path: relative, reason: 'Outside project root' });
      return;
    }
    const stats = await fsPromises.stat(fullPath);
    if (!stats.isFile()) return;
    if (stats.size > config.maxFileBytes) {
      skippedFiles.push({ path: relative, reason: `File exceeds maxFileBytes (${stats.size} bytes)` });
      return;
    }
    const ext = path.extname(relative).toLowerCase();
    if (!isAlwaysIncluded(relative) && !config.includeExtensions.includes(ext)) {
      return;
    }
    if (!visited.has(relative)) {
      visited.set(relative, { path: relative, fullPath, sizeBytes: stats.size });
    }
  }

  async function walkDirectory(directory, includeAll = false) {
    if (!fileExists(directory)) return;
    const entries = await fsPromises.readdir(directory, { withFileTypes: true });
    for (const entry of entries) {
      const fullPath = path.join(directory, entry.name);
      const relative = normalizeRelativePath(normalizedRoot, fullPath);
      if (shouldExclude(relative, config)) continue;
      if (entry.isDirectory()) {
        await walkDirectory(fullPath, includeAll);
        continue;
      }
      if (includeAll) {
        await addFile(fullPath);
      } else {
        const ext = path.extname(entry.name).toLowerCase();
        if (config.includeExtensions.includes(ext)) {
          await addFile(fullPath);
        }
      }
    }
  }

  for (const entry of config.alwaysIncludeFiles) {
    const full = path.join(normalizedRoot, entry);
    if (!fileExists(full)) continue;
    const stats = await fsPromises.stat(full);
    if (stats.isDirectory()) {
      await walkDirectory(full, true);
    } else if (stats.isFile()) {
      await addFile(full);
    }
  }

  for (const scanRoot of scanRoots) {
    const fullScanRoot = path.join(normalizedRoot, scanRoot);
    if (!fileExists(fullScanRoot)) continue;
    const stats = await fsPromises.stat(fullScanRoot);
    if (stats.isDirectory()) {
      await walkDirectory(fullScanRoot, false);
    } else if (stats.isFile()) {
      await addFile(fullScanRoot);
    }
  }

  return {
    files: Array.from(visited.values()),
    skippedFiles,
    totalBytes: Array.from(visited.values()).reduce((sum, entry) => sum + entry.sizeBytes, 0)
  };
}
