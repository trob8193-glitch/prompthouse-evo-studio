// PromptHouse Evo Studio — Chrome Extension
// manifest.json v3 — Browser Agent Bridge Pathway
// Truth State: built (pathway only — publishing requires Chrome Web Store account)
// Owner: Cipher Lynx (security) | Blueprint Orca (architecture)
// 
// BLOCKED: Extension publishing requires Chrome Developer account + review.
// Built: Extension package can be loaded locally via chrome://extensions -> Load unpacked.
{
  "manifest_version": 3,
  "name": "PromptHouse Evo Studio — Browser Agent Bridge",
  "short_name": "PH Evo Bridge",
  "version": "1.0.0",
  "description": "Captures page context, selected text, and URLs to send directly to your local PromptHouse Evo Studio via the PromptBridge API.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:3001/*",
    "http://localhost:5173/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PH Evo — Capture to Studio",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
